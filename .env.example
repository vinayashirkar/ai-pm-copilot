# ── Supabase (free at supabase.com) ─────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Google Gemini API (free at aistudio.google.com) ─────────────────────────
# Free tier: 1,500 req/day, 1M tokens/day — no credit card needed
GEMINI_API_KEY=your-gemini-api-key-here

# ── Groq API (free at console.groq.com) ─────────────────────────────────────
# Free tier: 30 req/min with Llama 3.1 70B — no credit card needed
GROQ_API_KEY=your-groq-api-key-here

# ── Resend Email (free at resend.com) ────────────────────────────────────────
# Free tier: 3,000 emails/month — no credit card needed
RESEND_API_KEY=your-resend-api-key-here
RESEND_FROM_EMAIL=copilot@yourdomain.com

# ── App config ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
